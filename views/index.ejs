<% layout('/layouts/boilerplate') %>
<body>
    
    <h2 class="index-heading">All Listings</h2>
    <div class="listings-container mb-3">
        <% for(listing of listings){ %>
            <a href="/listings/<%= listing._id %>" class="card-link">
            <div class="card listing-card h-100">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.image.filename %>" style="height: 20rem;">
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %></b><br>
                        &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
                    </p>
                </div>
            </div>
            </a>
        <% } %>
    </div>
</body>
